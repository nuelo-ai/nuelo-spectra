# .env.docker — Docker Compose environment variables for Spectra backend
# Copy to .env.docker and fill in API keys:
#   cp .env.docker.example .env.docker
#
# NOTE: DATABASE_URL and SPECTRA_MODE are set inline in compose.yaml — do not duplicate here

# App Version (used by GET /version endpoint)
# Set to the release tag (e.g., v0.6.0) at build time; defaults to "dev" if unset
APP_VERSION=

# JWT (required -- backend will fail without SECRET_KEY)
SECRET_KEY=local-dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Frontend URLs and CORS
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000","http://localhost:3001"]
ADMIN_CORS_ORIGIN=http://localhost:3001

# LLM API Keys (at least one required for agent functionality)
# Anthropic (default provider)
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google (Gemini)
GOOGLE_API_KEY=
# Ollama (local LLM — no API key needed, just the base URL)
OLLAMA_BASE_URL=
# OpenRouter (100+ models via single API key — https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# LangSmith (optional — tracing/debugging)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
LANGSMITH_PROJECT=

# E2B Sandbox (https://e2b.dev/dashboard)
E2B_API_KEY=

# Web Search (Tavily)
TAVILY_API_KEY=
# depth either 'basic' or 'advanced'
SEARCH_DEPTH=
SEARCH_DAILY_QUOTA=

# SMTP Email (optional — leave SMTP_HOST empty for dev mode console logging)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Admin credentials (REQUIRED when SPECTRA_MODE=dev or SPECTRA_MODE=admin)
# The admin user is automatically seeded on startup when these are set.
# For SPECTRA_MODE=public, leave these empty.
# WARNING: Changing admin password via the UI will be reset on container restart —
# the env var is the source of truth for the admin password.
ADMIN_EMAIL=
ADMIN_PASSWORD=

