# Database
DATABASE_URL=

# Server Mode
# Valid values:
#  - dev (default if unset) — exposes both public and admin routes
#  - public — public routes only, zero admin routes
#  - admin — admin routes only, zero public routes
SPECTRA_MODE=

# App Version (used by GET /version endpoint)
# Set to the release tag (e.g., v0.6.0) at build time; defaults to "dev" if unset
APP_VERSION=

# JWT Settings
SECRET_KEY=
ALGORITHM=
ACCESS_TOKEN_EXPIRE_MINUTES=
REFRESH_TOKEN_EXPIRE_DAYS=

# Frontend
FRONTEND_URL=
CORS_ORIGINS=

# SMTP Email Configuration
# Leave SMTP_HOST empty for dev mode (console logging)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# LLM Keys — at minimum set ANTHROPIC_API_KEY (default provider)
# Anthropic (default provider)
ANTHROPIC_API_KEY=
# OpenAI
OPENAI_API_KEY=
# Google (Gemini)
GOOGLE_API_KEY=
# Ollama (local LLM — no API key needed, just the base URL)
OLLAMA_BASE_URL=
# OpenRouter (100+ models via single API key — https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# LangSmith (optional — tracing/debugging)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=
LANGSMITH_PROJECT=

# E2B Sandbox (https://e2b.dev/dashboard)
E2B_API_KEY=

# Web Search (Tavily)
TAVILY_API_KEY=
# depth either 'basic' or 'advanced'
SEARCH_DEPTH=
SEARCH_DAILY_QUOTA=

# Admin Seed (optional — used by: uv run python -m app.cli seed-admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
