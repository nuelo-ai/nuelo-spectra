# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/spectra

# JWT Settings
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Frontend
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# SMTP Email Configuration
# Leave SMTP_HOST empty for dev mode (console logging)
# Gmail: SMTP_HOST=smtp.gmail.com SMTP_PORT=587
# SendGrid: SMTP_HOST=smtp.sendgrid.net SMTP_PORT=587
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@spectra.app
SMTP_FROM_NAME=Spectra

# LLM Keys — at minimum set ANTHROPIC_API_KEY (default provider)
# Anthropic (default provider)
ANTHROPIC_API_KEY=your-anthropic-api-key
# OpenAI
OPENAI_API_KEY=
# Google (Gemini)
GOOGLE_API_KEY=
# Ollama (local LLM — no API key needed, just the base URL)
OLLAMA_BASE_URL=http://localhost:11434
# OpenRouter (100+ models via single API key — https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# LangSmith (optional — tracing/debugging)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=spectra-agents

# E2B Sandbox (https://e2b.dev/dashboard)
E2B_API_KEY=your-e2b-api-key

# Web Search (Tavily)
TAVILY_API_KEY=your-tavily-api-key
SEARCH_DEPTH=basic
